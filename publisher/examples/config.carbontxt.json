{
  "adapter": {
    "type": "carbontxt-api",
    "options": {
      "provider": "ACME Hosting (compliance@acme.example)",
      "reportingPeriod": "2026-02",
      "domain": "acme.example",
      "fixture": {
        "success": true,
        "url": "https://acme.example/carbon.txt",
        "data": {
          "version": "0.5",
          "last_updated": "2026-06-01",
          "org": {
            "disclosures": [
              { "doc_type": "sustainability-page", "url": "https://acme.example/sustainability", "domain": "acme.example" },
              { "doc_type": "certificate", "url": "https://acme.example/iso14001.pdf", "title": "ISO 14001" }
            ]
          },
          "upstream": { "services": [{ "domain": "aws.amazon.com", "service_type": "shared-hosting" }] }
        },
        "logs": []
      },
      "compute": {
        "bytes": 2000000000,
        "green": true,
        "gridZone": "DEU"
      },
      "capabilities": "extended"
    }
  },
  "publisher": {
    "normalize": { "target": "acme.example" },
    "security": { "applyNoise": false },
    "cacheTtlMs": 0
  },
  "server": {
    "port": 8081,
    "maxAge": 86400,
    "carbonTxt": { "sustainabilityUrl": "https://acme.example/.well-known/sustainability" }
  }
}
