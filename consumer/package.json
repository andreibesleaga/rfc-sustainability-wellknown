  "description": "Reference client for /.well-known/sustainability (draft-besleaga-sustainability-wellknown): fetch, validate, and transform. Complements sustainability-wellknown-publisher.",
  "license": "BSD-3-Clause",
  "author": "Andrei Nicolae Besleaga",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreibesleaga/rfc-sustainability-wellknown.git",
    "directory": "consumer"
  },
  "homepage": "https://github.com/andreibesleaga/rfc-sustainability-wellknown/tree/main/consumer#readme",
  "bugs": {
    "url": "https://github.com/andreibesleaga/rfc-sustainability-wellknown/issues"
  },
